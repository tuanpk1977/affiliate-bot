{
  "candidate_limit": 200,
  "max_per_source": 40,
  "top_topics": 10,
  "calendar_days": 7,
  "validation_keywords": 10,
  "business_intelligence": {
    "evergreen": {
      "review_after_days": 30,
      "update_after_days": 90,
      "outdated_after_days": 180,
      "deprecated_after_days": 365,
      "broken_links_threshold": 1,
      "min_word_count": 500,
      "min_readability_score": 45,
      "duplicate_similarity_threshold": 0.72
    },
    "affiliate_opportunity": {
      "commercial_intent_weight": 0.18,
      "search_intent_weight": 0.10,
      "existing_programs_weight": 0.14,
      "estimated_commission_weight": 0.12,
      "estimated_conversion_weight": 0.10,
      "competition_weight": 0.10,
      "estimated_article_value_weight": 0.12,
      "content_difficulty_weight": 0.08,
      "topic_freshness_weight": 0.04,
      "seasonality_weight": 0.02
    },
    "content_gap": {
      "max_report_rows": 100
    },
    "affiliate_coverage": {
      "max_missing_products": 5
    }
  },
  "research_intelligence": {
    "cache_enabled": true,
    "max_semantic_keywords": 8,
    "max_long_tail_keywords": 10,
    "max_competitors": 5,
    "min_research_quality_score": 60,
    "allow_generation_override": false,
    "auto_refresh_weekly_on_monday": true,
    "quality_gate": {
      "enabled": true,
      "threshold": 60,
      "allow_override": false
    },
    "verified_source_gate": {
      "enabled": true,
      "minimum_official_docs_score": 20,
      "minimum_pricing_source_score": 20,
      "minimum_affiliate_source_score": 10,
      "minimum_total_score": 35
    },
    "enrichment_queue": {
      "default_status": "pending",
      "high_priority_below_score": 45,
      "medium_priority_below_score": 60
    }
  },
  "knowledge_review": {
    "freshness_threshold": 35,
    "review_after_days": 90,
    "expire_after_days": 365,
    "minimum_verified_sources": 2,
    "minimum_official_sources": 1,
    "minimum_trust_score": 50,
    "minimum_freshness": 35,
    "duplicate_similarity": 0.88
  },
  "content_review": {
    "minimum_word_count": 900,
    "minimum_publish_readiness": 65,
    "minimum_readability_score": 35,
    "maximum_duplicate_risk": 65,
    "require_human_approval": true,
    "manual_approval_article_types": [
      "affiliate",
      "review",
      "pricing",
      "comparison",
      "product_recommendation"
    ],
    "manual_approval_title_markers": [
      " pricing",
      " review",
      " comparison",
      " vs ",
      " best ",
      " alternative",
      " alternatives",
      "recommend"
    ]
  },
  "human_approval": {
    "required": true
  },
  "threshold_policy": {
    "enabled": true,
    "mode": "staged",
    "initial_thresholds": {
      "minimum_usable_sources": 2,
      "research_quality_score": 50,
      "entity_coverage_score": 40,
      "competitor_coverage_score": 30,
      "freshness_score": 40,
      "ai_review_score": 60
    },
    "critical_minimums": {
      "minimum_usable_sources": 1,
      "research_quality_score": 35,
      "entity_mismatch": true,
      "source_mismatch": true,
      "duplicate_collision": true
    },
    "soft_quality_gates": [
      "competitor_coverage",
      "entity_coverage",
      "affiliate_verification",
      "research_quality_score",
      "freshness_score",
      "semantic_score"
    ]
  },
  "editorial_capacity": {
    "minimum_daily_review_ready": 5,
    "target_daily_review_ready": 10,
    "maximum_daily_drafts": 15,
    "max_parallel_topics": 3,
    "max_rewrite_attempts": 2,
    "max_review_cycles": 3,
    "daily_failure_budget": 5,
    "allow_warning_only_review": true
  },
  "quality_policy": {
    "hard_blockers": {
      "zero_usable_sources": true,
      "critical_research_failure": true,
      "critical_claim_unverified": true,
      "entity_source_mismatch": true,
      "duplicate_collision": true,
      "invalid_structure": true,
      "missing_human_approval": true,
      "render_failure": true
    },
    "soft_gates": {
      "low_entity_coverage": true,
      "low_competitor_coverage": true,
      "low_freshness": true,
      "thin_source_count_above_minimum": true,
      "readability_issue": true,
      "seo_issue": true,
      "business_value_issue": true,
      "minor_fact_uncertainty": true,
      "affiliate_verification": true
    }
  },
  "ai_review_v2": {
    "enabled": true,
    "schema_version": 2,
    "critical_status": "blocked",
    "warning_status": "warning",
    "review_ready_status": "needs_human_review"
  },
  "targeted_rewrite": {
    "enabled": true,
    "max_rewrite_attempts": 2,
    "max_review_cycles": 3,
    "keep_better_section": true
  },
  "fact_verification": {
    "enabled": true,
    "cache_by_claim_hash": true,
    "critical_unsupported_claim_blocks": true,
    "minor_unsupported_claim_warns": true
  },
  "source_ranking": {
    "enabled": true,
    "allow_tier_3_and_4_for_context": true,
    "disallow_low_tier_as_only_critical_claim_source": true
  },
  "ai_judge": {
    "enabled": true,
    "block_only_on_critical": true,
    "warning_only_goes_to_human": true
  },
  "publishing_confidence": {
    "pass_min": 90,
    "review_ready_min": 75,
    "rewrite_min": 50,
    "hard_blocker_overrides_score": true
  },
  "editorial_brain": {
    "enabled": true,
    "daily_mix": {
      "fast_track": 0.4,
      "standard": 0.4,
      "deep_research": 0.2
    },
    "classifications": [
      "FAST_TRACK",
      "STANDARD",
      "DEEP_RESEARCH",
      "HOLD",
      "REJECT"
    ]
  },
  "knowledge_graph": {
    "enabled": true,
    "storage": "json",
    "hard_block_only_on_entity_mismatch": true
  },
  "continuous_learning": {
    "enabled": true,
    "weekly_report": true,
    "auto_apply_threshold_changes": false,
    "requires_human_approval_for_policy_change": true
  },
  "publish_gate": {
    "enabled": true,
    "minimum_verified_source_score": 35,
    "minimum_knowledge_freshness": 20,
    "require_human_approval": true,
    "minimum_business_score": 35,
    "minimum_readability_score": 30,
    "scoring_bands": {
      "high_confidence_min": 80,
      "human_review_min": 65,
      "needs_revision_min": 50,
      "blocked_below": 50
    }
  },
  "analytics_optimization": {
    "enabled": true,
    "conversion_rate_estimate": 0.08,
    "average_conversion_value": 12.5
  },
  "published_live_duplicate_guard": {
    "mode": "deprioritize",
    "score_penalty": 4.0
  }
}
